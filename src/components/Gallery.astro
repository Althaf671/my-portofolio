---
const codeScreenshots = [
  { src: "/administrator.webp", alt: "CORE Platform - Administrator Entity with Domain Driven Design." },
  { src: "/interface.webp", alt: "CORE Platform - Interface Personal Service Layer 1" },
  { src: "/registration.webp", alt: "CORE Platform - Administrator Registration" },
  { src: "/ace-hero.webp", alt: "Ace Train - Hero Section" },
  { src: "/authorization.webp", alt: "CORE Platform - Authorization Policies Registry" },
];
---

<section id="project" style="width: 95%;">
    <h2 style="border-bottom: 1px solid grey; padding-bottom: 0.75rem;"># Code in Actions</h2>
    <div class="marquee-container">
        <div class="marquee-content">
            {[...codeScreenshots, ...codeScreenshots].map((img) => (
                <div class="code-card">
                    <img 
                        src={img.src} 
                        alt={img.alt} 
                        onclick={`openModal('${img.src}', '${img.alt}')`}
                        style="cursor: pointer;"
                    />
                </div>
            ))}
        </div>
    </div>
</section>

<dialog id="code-modal">
    <div class="modal-wrapper">
        <img id="modal-img" src="" alt="" />
        <p id="modal-caption"></p>
        <button id="close-modal">Close</button>
    </div>
</dialog>

<script is:inline>
    const modal = document.getElementById('code-modal');
    const modalImg = document.getElementById('modal-img');
    const modalCaption = document.getElementById('modal-caption');
    const closeBtn = document.getElementById('close-modal');

    window.openModal = (src, alt) => {
        modalImg.src = src;
        modalCaption.innerText = alt;
        modal.showModal();
    };

    closeBtn.onclick = () => modal.close();
    
    modal.addEventListener('click', (e) => {
        if (e.target === modal) modal.close();
    });
</script>

<style>
    dialog#code-modal {
        background: transparent;
        border: none;
        padding: 0;
        outline: none;
        max-width: 95vw;
        max-height: 95vh;
        overflow: hidden;
    }

    dialog#code-modal::backdrop {
        background: rgba(0, 0, 0, 0.85);
        backdrop-filter: blur(4px);
    }

    .modal-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    #modal-img {
        width: 100%;
        max-height: 75vh;
        object-fit: contain;
        border: 1px solid #333;
        border-radius: 8px;
    }

    #modal-caption {
        color: white;
        margin-top: 1rem;
        font-family: 'inter', sans-serif;
        font-size: 16px;
        text-align: center;
    }

    #close-modal {
        margin-top: 1.5rem;
        background-color: rgb(0, 123, 255);
        color: white;
        border: none;
        padding: 8px 20px;
        border-radius: 2px;
        cursor: pointer;
        font-family: 'inter', sans-serif;
        margin-top: 0px;
        outline: none;
    }

    #close-modal:hover {
        background: #333;
    }
</style>

<style>
    .marquee-container {
        width: 100%;
        overflow: hidden;
        background: #000;
        padding: 2rem 0;
        mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
        -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    }

    .marquee-content {
        display: flex;
        gap: 1.5rem;
        width: max-content;
        animation: scroll 40s linear infinite;
    }

    .marquee-content:hover {
        animation-play-state: paused;
    }

    .code-card {
        width: 400px; 
        height: 250px;
        flex-shrink: 0;
        border: 1px solid #333;
        border-radius: 4px;
        overflow: hidden;
        transition: transform 0.3s ease;
    }

    .code-card:hover {
        transform: scale(1.02);
        border-color: #555;
    }

    .code-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    @keyframes scroll {
        from { transform: translateX(0); }
        to { transform: translateX(-50%); }
    }
</style>